<?xml version="1.0" encoding="UTF-8"?>
<soap:Envelope xmlns:soap="http://www.w3.org/2003/05/soap-envelope"
    xmlns:tev="http://www.onvif.org/ver10/events/wsdl"
    xmlns:wsnt="http://docs.oasis-open.org/wsn/b-2"
    xmlns:tt="http://www.onvif.org/ver10/schema">
  <soap:Body>
    <tev:PullMessagesResponse>
      <tev:CurrentTime>{{ current_time }}</tev:CurrentTime>
      <tev:TerminationTime>{{ termination_time }}</tev:TerminationTime>
      {% for m in messages %}
      <wsnt:NotificationMessage>
        <wsnt:Topic Dialect="http://www.onvif.org/ver10/tev/topicExpression/ConcreteSet">{{ m.topic }}</wsnt:Topic>
        <wsnt:Message>
          <tt:Message UtcTime="{{ m.utc_time }}" PropertyOperation="Changed">
            <tt:Source>
              <tt:SimpleItem Name="Source" Value="{{ m.source_token }}"/>
            </tt:Source>
            <tt:Key>
              <tt:SimpleItem Name="ObjectId" Value="{{ m.object_id }}"/>
            </tt:Key>
            <tt:Data>
              <tt:SimpleItem Name="{{ m.field_name }}" Value="{{ 'true' if m.state else 'false' }}"/>
            </tt:Data>
          </tt:Message>
        </wsnt:Message>
      </wsnt:NotificationMessage>
      {% endfor %}
    </tev:PullMessagesResponse>
  </soap:Body>
</soap:Envelope>
